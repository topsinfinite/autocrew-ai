# Public app URL (required in production for SEO: sitemap, robots, Open Graph, canonical URLs)
# e.g. https://autocrew.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ElevenLabs TTS (voice demo on landing page)
ELEVENLABS_API_KEY=

# Beehiiv email marketing (newsletter signup form)
# API key: Settings > API at https://app.beehiiv.com
BEEHIIV_API_KEY=
# Publication ID: format pub_xxxxxxxxx
BEEHIIV_PUBLICATION_ID=
# Welcome automation ID: format aut_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Ensure automation is Published and Active with trigger: utm_source=autocrew-ai AND utm_medium=signup-form
BEEHIIV_AUTOMATION_WELCOME=
