# Public app URL (required in production for SEO: sitemap, robots, Open Graph, canonical URLs)
# e.g. https://autocrew.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ElevenLabs TTS (voice demo on landing page)
ELEVENLABS_API_KEY=

# Beehiiv email marketing (newsletter signup form)
# API key: Settings > API at https://app.beehiiv.com
BEEHIIV_API_KEY=
# Publication ID: format pub_xxxxxxxxx
BEEHIIV_PUBLICATION_ID=
# Welcome automation ID: format aut_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Ensure automation is Published and Active with trigger: utm_source=autocrew-ai AND utm_medium=signup-form
BEEHIIV_AUTOMATION_WELCOME=

# Contextual AI (Highlight-to-Chat) — Phase 1 prototype
# Default on in all environments. Set to "false" to disable globally.
NEXT_PUBLIC_CONTEXTUAL_AI_ENABLED=true

# When "true" AND window.AutoCrew.prefillWithContext is not present, clicking
# "Ask Sarah" shows a debug card with the payload the widget would receive.
# Leave unset in production; set to "true" locally for dogfood.
NEXT_PUBLIC_CONTEXTUAL_AI_STUB=

# ---------------------------------------------------------------------
# Blog cover image generation (scripts/generate-blog-covers.mjs)
# Run: npm run blog:covers
# ---------------------------------------------------------------------

# Recraft v3 — primary image generator. ~$0.04/image. Best for editorial
# illustration with brand consistency. Sign up: https://www.recraft.ai
RECRAFT_API_KEY=

# Recraft style ID — locks every cover to the same visual identity. Strongly
# recommended. Create one in the Recraft dashboard ("Styles" tab) by uploading
# 3-5 reference illustrations, then copy the style ID here. Without it, the
# script falls back to Recraft's "digital_illustration" preset (still good,
# just less brand-locked). Format: a UUID string.
RECRAFT_STYLE_ID=

# OpenAI gpt-image-1 — fallback if Recraft fails. Quality "medium" ~$0.042.
# https://platform.openai.com
OPENAI_API_KEY=
